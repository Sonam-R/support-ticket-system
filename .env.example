# =============================================================================
# Support Ticket System — Environment Variables
# Copy this file to `.env` and update values before running the application.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (used by Docker Compose and local development)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=support_ticket_system

# -----------------------------------------------------------------------------
# Database
# Local development (without Docker):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/support_ticket_system
# Docker Compose (backend service uses internal hostname automatically):
#   DATABASE_URL=postgresql://postgres:postgres@postgres:5432/support_ticket_system
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/support_ticket_system

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
PORT=5001
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=24h
NODE_ENV=development

# -----------------------------------------------------------------------------
# Frontend
# Local Vite dev server: use /api (proxied to backend)
# Docker production build: use the URL reachable from the browser
# -----------------------------------------------------------------------------
VITE_API_URL=/api
FRONTEND_PORT=3000
